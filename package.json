{
  "name": "firmware-task-manager",
  "displayName": "Firmware Task Manager",
  "version": "1.1.2",
  "description": "Run VSCode tasks with interactive parameter prompts (serial port, file path, free text) for firmware development workflows.",
  "categories": [
    "Other"
  ],
  "keywords": [
    "firmware",
    "task",
    "embedded",
    "serialport",
    "stm32",
    "esp32"
  ],
  "license": "MIT",
  "publisher": "baram-dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/Holiday-Robot/firmware-vscode-task.git"
  },
  "bugs": {
    "url": "https://github.com/Holiday-Robot/firmware-vscode-task/issues"
  },
  "homepage": "https://github.com/Holiday-Robot/firmware-vscode-task#readme",
  "main": "./dist/extension.js",
  "scripts": {
    "compile": "pnpm run check-types && pnpm run lint && rolldown -c",
    "watch": "npm-run-all -p watch:*",
    "watch:build": "rolldown -c -w",
    "watch:tsc": "tsgo --noEmit --watch --project tsconfig.json",
    "package": "pnpm run check-types && pnpm run lint && cross-env NODE_ENV=production rolldown -c",
    "compile-tests": "rimraf out && tsgo -p . --outDir out",
    "watch-tests": "tsgo -p . -w --outDir out",
    "pretest": "pnpm run compile-tests && pnpm run compile && pnpm run lint",
    "check-types": "tsgo --noEmit",
    "lint": "oxlint --config .oxlintrc.json --type-aware src",
    "test": "vscode-test",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "vsix": "pnpm run package && mkdir -p dist-vsix && vsce package --no-dependencies --allow-missing-repository --out dist-vsix/"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.0.0",
    "@types/vscode": "1.103.0",
    "@typescript/native-preview": "7.0.0-dev.20260421.2",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.2.0",
    "cross-env": "^10.1.0",
    "jsonc-parser": "^3.3.1",
    "npm-run-all": "^4.1.5",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.19.0",
    "rimraf": "^6.1.3",
    "rolldown": "1.0.0-rc.17"
  },
  "contributes": {
    "commands": [
      {
        "command": "firmware-task.refresh",
        "title": "Refresh Tasks",
        "category": "Firmware Task Manager",
        "icon": "$(sync)"
      },
      {
        "command": "firmware-task.configure",
        "title": "Configure Task",
        "category": "Firmware Task Manager",
        "icon": "$(gear)"
      },
      {
        "command": "firmware-task.terminateAll",
        "title": "Terminate All Running Tasks",
        "category": "Firmware Task Manager",
        "icon": "$(debug-stop)"
      },
      {
        "command": "firmware-task.run",
        "title": "Run Task",
        "category": "Firmware Task Manager",
        "icon": "$(debug-start)"
      },
      {
        "command": "firmware-task.viewSource",
        "title": "View Source",
        "category": "Firmware Task Manager",
        "icon": "$(go-to-file)"
      },
      {
        "command": "firmware-task.terminate",
        "title": "Terminate Task",
        "category": "Firmware Task Manager",
        "icon": "$(debug-stop)"
      },
      {
        "command": "firmware-task.restart",
        "title": "Restart Task",
        "category": "Firmware Task Manager",
        "icon": "$(debug-restart)"
      },
      {
        "command": "firmware-task.favorite",
        "title": "Favorite Task",
        "category": "Firmware Task Manager",
        "icon": "$(star-empty)"
      },
      {
        "command": "firmware-task.unfavorite",
        "title": "Unfavorite Task",
        "category": "Firmware Task Manager",
        "icon": "$(star-full)"
      },
      {
        "command": "firmware-task.pickSerialPort",
        "title": "Pick Serial Port",
        "category": "Firmware Task Manager"
      },
      {
        "command": "firmware-task.promptInput",
        "title": "Prompt Input",
        "category": "Firmware Task Manager"
      },
      {
        "command": "firmware-task.pickFile",
        "title": "Pick File",
        "category": "Firmware Task Manager"
      },
      {
        "command": "firmware-task.pickFolder",
        "title": "Pick Folder",
        "category": "Firmware Task Manager"
      },
      {
        "command": "firmware-task.pickFromList",
        "title": "Pick From List",
        "category": "Firmware Task Manager"
      },
      {
        "command": "firmware-task.configureInputs",
        "title": "Configure Inputs",
        "category": "Firmware Task Manager",
        "icon": "$(settings-gear)"
      },
      {
        "command": "firmware-task.copyCommand",
        "title": "Copy Command Line",
        "category": "Firmware Task Manager",
        "icon": "$(clippy)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "firmware-task.tasks",
          "name": "Firmware Tasks",
          "icon": "$(tasklist)"
        }
      ]
    },
    "menus": {
      "commandPalette": [
        {
          "command": "firmware-task.refresh",
          "when": "false"
        },
        {
          "command": "firmware-task.configure",
          "when": "false"
        },
        {
          "command": "firmware-task.terminateAll",
          "when": "false"
        },
        {
          "command": "firmware-task.run",
          "when": "false"
        },
        {
          "command": "firmware-task.viewSource",
          "when": "false"
        },
        {
          "command": "firmware-task.terminate",
          "when": "false"
        },
        {
          "command": "firmware-task.restart",
          "when": "false"
        },
        {
          "command": "firmware-task.favorite",
          "when": "false"
        },
        {
          "command": "firmware-task.unfavorite",
          "when": "false"
        },
        {
          "command": "firmware-task.pickSerialPort",
          "when": "false"
        },
        {
          "command": "firmware-task.promptInput",
          "when": "false"
        },
        {
          "command": "firmware-task.pickFile",
          "when": "false"
        },
        {
          "command": "firmware-task.pickFolder",
          "when": "false"
        },
        {
          "command": "firmware-task.pickFromList",
          "when": "false"
        },
        {
          "command": "firmware-task.configureInputs",
          "when": "false"
        },
        {
          "command": "firmware-task.copyCommand",
          "when": "false"
        }
      ],
      "view/title": [
        {
          "command": "firmware-task.refresh",
          "when": "view == firmware-task.tasks",
          "group": "navigation@1"
        },
        {
          "command": "firmware-task.configure",
          "when": "view == firmware-task.tasks",
          "group": "navigation@2"
        },
        {
          "command": "firmware-task.terminateAll",
          "when": "view == firmware-task.tasks"
        }
      ],
      "view/item/context": [
        {
          "command": "firmware-task.configureInputs",
          "when": "view == firmware-task.tasks && (viewItem == taskWithInputs || viewItem == favoriteTaskWithInputs || viewItem == runningTaskWithInputs || viewItem == runningFavoriteTaskWithInputs)",
          "group": "inline@0"
        },
        {
          "command": "firmware-task.run",
          "when": "view == firmware-task.tasks && (viewItem == task || viewItem == favoriteTask || viewItem == taskWithInputs || viewItem == favoriteTaskWithInputs)",
          "group": "inline@1"
        },
        {
          "command": "firmware-task.terminate",
          "when": "view == firmware-task.tasks && (viewItem == runningTask || viewItem == runningFavoriteTask || viewItem == runningTaskWithInputs || viewItem == runningFavoriteTaskWithInputs)",
          "group": "inline@1"
        },
        {
          "command": "firmware-task.restart",
          "when": "view == firmware-task.tasks && (viewItem == runningTask || viewItem == runningFavoriteTask || viewItem == runningTaskWithInputs || viewItem == runningFavoriteTaskWithInputs)",
          "group": "inline@2"
        },
        {
          "command": "firmware-task.viewSource",
          "when": "view == firmware-task.tasks && (viewItem == task || viewItem == favoriteTask || viewItem == runningTask || viewItem == runningFavoriteTask || viewItem == taskWithInputs || viewItem == favoriteTaskWithInputs || viewItem == runningTaskWithInputs || viewItem == runningFavoriteTaskWithInputs)",
          "group": "inline@3"
        },
        {
          "command": "firmware-task.copyCommand",
          "when": "view == firmware-task.tasks && (viewItem == task || viewItem == favoriteTask || viewItem == runningTask || viewItem == runningFavoriteTask || viewItem == taskWithInputs || viewItem == favoriteTaskWithInputs || viewItem == runningTaskWithInputs || viewItem == runningFavoriteTaskWithInputs)",
          "group": "inline@4"
        },
        {
          "command": "firmware-task.favorite",
          "when": "view == firmware-task.tasks && (viewItem == task || viewItem == runningTask || viewItem == taskWithInputs || viewItem == runningTaskWithInputs)",
          "group": "inline@5"
        },
        {
          "command": "firmware-task.unfavorite",
          "when": "view == firmware-task.tasks && (viewItem == favoriteTask || viewItem == runningFavoriteTask || viewItem == favoriteTaskWithInputs || viewItem == runningFavoriteTaskWithInputs)",
          "group": "inline@5"
        }
      ]
    },
    "configuration": [
      {
        "title": "Firmware Task Manager",
        "properties": {
          "firmwareTask.exclude": {
            "type": "string",
            "default": null,
            "description": "Regular expression pattern for excluding tasks by name."
          },
          "firmwareTask.collapseLargeTaskTree": {
            "type": "boolean",
            "default": true,
            "description": "Collapse the task tree to top-level groups when there are more than three groups and more than 30 tasks."
          },
          "firmwareTask.taskSortOrder": {
            "type": "string",
            "default": "label",
            "enum": [
              "label",
              "group",
              "provider"
            ],
            "enumDescriptions": [
              "Sort tasks alphabetically by label.",
              "Sort tasks by task group, then alphabetically by label.",
              "Keep tasks in the order returned by VS Code task providers."
            ],
            "description": "Controls how task items are sorted."
          },
          "firmwareTask.favorites": {
            "type": "array",
            "default": [],
            "items": {
              "type": "string"
            },
            "description": "Favorite task identifiers saved in workspace settings."
          },
          "firmwareTask.showOnlyWorkspaceTasks": {
            "type": "boolean",
            "default": true,
            "description": "Show only tasks defined in .vscode/tasks.json. When false, also show auto-detected tasks (CMake, npm, tsc, etc.)."
          },
          "firmwareTask.rememberInputs": {
            "type": "boolean",
            "default": true,
            "description": "Remember last entered input values per task and pre-fill them on subsequent runs."
          },
          "firmwareTask.serialPortFilter": {
            "type": "string",
            "default": "",
            "description": "Regular expression applied to detected serial port device names."
          },
          "firmwareTask.groupByNameSeparator": {
            "type": "string",
            "default": "-",
            "description": "Group tasks in the tree by splitting their names with this separator. Sibling tasks sharing the same prefix are nested under a group node. Set to empty string to disable grouping."
          }
        }
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "icon": "images/logo.png",
  "engines": {
    "vscode": "^1.103.0"
  },
  "packageManager": "pnpm@10.33.0"
}
